#!/bin/bash

# Provider contract:
# - probe: exit 0 when this backend is supported on the current machine
# - list: print supported policies as "id|Label" lines
# - status: print the active policy id
# - set <policy-id>: apply one built-in policy
# - set-custom <start> <end>: apply a custom charge range
#
# Use this file as the structure reference for new
# omarchy-battery-policy-provider-<name> implementations.

ATTRIBUTES_DIR=/sys/class/firmware-attributes/dell-wmi-sysman/attributes

show_help() {
  cat <<'EOF'
Usage: omarchy-battery-policy-provider-dell-sysman <command> [arguments]

Dell BIOS battery policy provider.

Commands:
  probe                 Exit successfully when this provider is supported
  list                  Print supported policies as id|Label lines
  status                Print provider status as key=value lines
  set <policy>          Apply a built-in battery charging policy
  set-custom <start> <end>
                        Apply a custom charge threshold range
EOF
}

battery_dir() {
  local bat

  for bat in /sys/class/power_supply/BAT*; do
    [[ -d $bat ]] || continue
    [[ -r $bat/type ]] || continue
    [[ $(<"$bat/type") == "Battery" ]] || continue

    if [[ -r $bat/charge_types || -r $bat/charge_control_end_threshold ]]; then
      printf '%s\n' "$bat"
      return 0
    fi
  done

  return 1
}

policy_id_from_raw() {
  case "$1" in
  Adaptive) printf '%s\n' adaptive ;;
  Standard) printf '%s\n' standard ;;
  Express | Fast) printf '%s\n' fast ;;
  Custom) printf '%s\n' custom ;;
  PrimAcUse) printf '%s\n' primarily-ac ;;
  *) return 1 ;;
  esac
}

policy_label_from_id() {
  case "$1" in
  adaptive) printf '%s\n' Adaptive ;;
  standard) printf '%s\n' Standard ;;
  fast) printf '%s\n' Express ;;
  custom) printf '%s\n' Custom ;;
  primarily-ac) printf '%s\n' 'Primarily AC Use' ;;
  *) return 1 ;;
  esac
}

raw_from_policy_id() {
  case "$1" in
  adaptive) printf '%s\n' Adaptive ;;
  standard) printf '%s\n' Standard ;;
  fast) printf '%s\n' Express ;;
  custom) printf '%s\n' Custom ;;
  primarily-ac) printf '%s\n' PrimAcUse ;;
  *) return 1 ;;
  esac
}

raw_policy_for_firmware() {
  local policy_id="$1"

  case "$policy_id" in
  fast)
    if supports_raw_policy Fast; then
      printf '%s\n' Fast
    else
      printf '%s\n' Express
    fi
    ;;
  *) raw_from_policy_id "$policy_id" ;;
  esac
}

active_charge_type() {
  local bat="$1"
  local raw_types

  [[ -r $bat/charge_types ]] || return 1

  raw_types=$(<"$bat/charge_types")
  if [[ $raw_types =~ \[([^][]+)\] ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi

  return 1
}

possible_values() {
  [[ -r $ATTRIBUTES_DIR/PrimaryBattChargeCfg/possible_values ]] || return 1
  tr ';' '\n' < "$ATTRIBUTES_DIR/PrimaryBattChargeCfg/possible_values"
}

supports_raw_policy() {
  local raw_policy="$1"
  local candidate

  while IFS= read -r candidate; do
    [[ $candidate == "$raw_policy" ]] && return 0
  done < <(possible_values)

  return 1
}

is_integer() {
  [[ $1 =~ ^[0-9]+$ ]]
}

read_current_value() {
  local attribute="$1"
  sudo dd if="$ATTRIBUTES_DIR/$attribute/current_value" bs=128 count=1 status=none
}

read_current_value_cached() {
  local attribute="$1"
  sudo -n dd if="$ATTRIBUTES_DIR/$attribute/current_value" bs=128 count=1 status=none 2>/dev/null
}

write_current_value() {
  local attribute="$1"
  local value="$2"

  printf '%s\n' "$value" | sudo tee "$ATTRIBUTES_DIR/$attribute/current_value" >/dev/null
}

ensure_disabled() {
  local attribute="$1"
  local description="$2"
  local current_value

  # Use non-interactive sudo so we don't prompt mid-TUI; if the read fails
  # (no cached credentials), skip the check rather than blocking the user.
  current_value=$(read_current_value_cached "$attribute") || true

  if [[ -n $current_value && $current_value != "Disabled" ]]; then
    echo "$description must be disabled before changing battery charging settings." >&2
    exit 1
  fi
}

ensure_no_conflicts() {
  ensure_disabled AdvBatteryChargeCfg 'Advanced Battery Charge'
  ensure_disabled PeakShiftCfg 'Peak Shift'
}

# Detect whether the Dell Sysman firmware interface is available.
probe() {
  [[ -r $ATTRIBUTES_DIR/PrimaryBattChargeCfg/possible_values ]]
}

# Report the active policy plus custom threshold support and values.
status() {
  local bat
  local active_policy=""
  local active_raw=""
  local custom_active=false
  local custom_start=""
  local custom_end=""
  local firmware_policy=""
  local firmware_start=""
  local firmware_end=""
  local pending_reboot=0

  bat=$(battery_dir 2>/dev/null || true)
  [[ -r $ATTRIBUTES_DIR/pending_reboot ]] && pending_reboot=$(<"$ATTRIBUTES_DIR/pending_reboot")

  firmware_policy=$(read_current_value_cached PrimaryBattChargeCfg || true)
  firmware_start=$(read_current_value_cached CustomChargeStart || true)
  firmware_end=$(read_current_value_cached CustomChargeStop || true)

  if [[ -n $firmware_policy ]]; then
    active_raw=$firmware_policy
    active_policy=$(policy_id_from_raw "$active_raw" 2>/dev/null || true)
  elif [[ -n $bat ]] && active_raw=$(active_charge_type "$bat" 2>/dev/null); then
    active_policy=$(policy_id_from_raw "$active_raw" 2>/dev/null || true)
  fi

  [[ $active_policy == custom ]] && custom_active=true

  if [[ -n $firmware_start ]]; then
    custom_start=$firmware_start
  elif [[ -n $bat && -r $bat/charge_control_start_threshold ]]; then
    custom_start=$(<"$bat/charge_control_start_threshold")
  fi

  if [[ -n $firmware_end ]]; then
    custom_end=$firmware_end
  elif [[ -n $bat && -r $bat/charge_control_end_threshold ]]; then
    custom_end=$(<"$bat/charge_control_end_threshold")
  fi

  printf '%s\n' 'provider=dell-sysman'
  if [[ -n $bat ]]; then
    printf '%s\n' "battery=$(basename "$bat")"
  else
    printf '%s\n' 'battery=system'
  fi
  printf '%s\n' "active_policy=$active_policy"
  printf '%s\n' "active_raw=$active_raw"
  printf '%s\n' 'custom_supported=true'
  printf '%s\n' "custom_active=$custom_active"
  printf '%s\n' 'custom_start_supported=true'
  printf '%s\n' 'custom_end_supported=true'
  local custom_start_min="" custom_start_max="" custom_end_min="" custom_end_max=""
  [[ -r $ATTRIBUTES_DIR/CustomChargeStart/min_value ]] && custom_start_min=$(<"$ATTRIBUTES_DIR/CustomChargeStart/min_value")
  [[ -r $ATTRIBUTES_DIR/CustomChargeStart/max_value ]] && custom_start_max=$(<"$ATTRIBUTES_DIR/CustomChargeStart/max_value")
  [[ -r $ATTRIBUTES_DIR/CustomChargeStop/min_value ]]  && custom_end_min=$(<"$ATTRIBUTES_DIR/CustomChargeStop/min_value")
  [[ -r $ATTRIBUTES_DIR/CustomChargeStop/max_value ]]  && custom_end_max=$(<"$ATTRIBUTES_DIR/CustomChargeStop/max_value")

  printf '%s\n' "custom_start=$custom_start"
  printf '%s\n' "custom_end=$custom_end"
  printf '%s\n' "custom_start_min=$custom_start_min"
  printf '%s\n' "custom_start_max=$custom_start_max"
  printf '%s\n' "custom_end_min=$custom_end_min"
  printf '%s\n' "custom_end_max=$custom_end_max"
  printf '%s\n' "pending_reboot=$pending_reboot"
}

# List the built-in policy ids and labels exposed by the firmware.
list() {
  local raw_policy
  local policy_id

  while IFS= read -r raw_policy; do
    [[ -n $raw_policy ]] || continue
    policy_id=$(policy_id_from_raw "$raw_policy" 2>/dev/null || true)
    [[ -n $policy_id ]] || continue
    printf '%s|%s\n' "$policy_id" "$(policy_label_from_id "$policy_id")"
  done < <(possible_values)
}

# Apply one named built-in policy through the firmware attributes.
set_policy() {
  local raw_policy

  raw_policy=$(raw_policy_for_firmware "$1") || {
    echo "Unsupported battery policy: $1" >&2
    exit 1
  }

  if ! supports_raw_policy "$raw_policy"; then
    echo "Battery policy '$1' is not available on this machine." >&2
    exit 1
  fi

  ensure_no_conflicts
  write_current_value PrimaryBattChargeCfg "$raw_policy" || exit 1
}

# Validate and apply custom charge start and stop thresholds.
set_custom_policy() {
  local start="$1"
  local end="$2"
  local start_min
  local start_max
  local end_min
  local end_max

  start_min=$(<"$ATTRIBUTES_DIR/CustomChargeStart/min_value")
  start_max=$(<"$ATTRIBUTES_DIR/CustomChargeStart/max_value")
  end_min=$(<"$ATTRIBUTES_DIR/CustomChargeStop/min_value")
  end_max=$(<"$ATTRIBUTES_DIR/CustomChargeStop/max_value")

  is_integer "$start" || {
    echo "Start threshold must be an integer." >&2
    exit 1
  }

  is_integer "$end" || {
    echo "Stop threshold must be an integer." >&2
    exit 1
  }

  if (( start < start_min || start > start_max )); then
    echo "Start threshold must be between $start_min and $start_max." >&2
    exit 1
  fi

  if (( end < end_min || end > end_max )); then
    echo "Stop threshold must be between $end_min and $end_max." >&2
    exit 1
  fi

  if (( end < start + 5 )); then
    echo "Stop threshold must be at least 5% above the start threshold." >&2
    exit 1
  fi

  ensure_no_conflicts
  write_current_value PrimaryBattChargeCfg Custom || exit 1
  write_current_value CustomChargeStart "$start" || exit 1
  write_current_value CustomChargeStop "$end" || exit 1
}

# Dispatch the provider contract subcommands used by the battery policy wrappers.
case "$1" in
-h | --help) show_help ;;
probe) probe ;;
status) status ;;
list) list ;;
set) set_policy "$2" ;;
set-custom) set_custom_policy "$2" "$3" ;;
*) exit 1 ;;
esac
